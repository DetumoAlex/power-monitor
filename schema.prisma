// Prisma schema for Power/Light + Token Monitor
// Provider: MongoDB (matches Amanda's existing stack)
// Run `npx prisma generate` after setting DATABASE_URL in .env

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// A single monitored household/device. One household could technically
// have more than one device later (e.g. one per meter), so this is
// modeled as its own entity rather than assuming 1 user = 1 device.
model Device {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String   // e.g. "Alx - Yaba compound"
  ownerPhone  String   // WhatsApp number, used for bot delivery
  location    String?
  createdAt   DateTime @default(now())

  powerEvents PowerEvent[]
  tokenEntries TokenEntry[]
}

// Every time the sensor detects a transition (mains present -> absent,
// or absent -> present), one row is written. We deliberately store
// transitions, not periodic samples — cheaper on the device's battery
// and connectivity budget, and all the analytics (hours/day, week, month)
// can be derived from transitions alone.
model PowerEvent {
  id        String     @id @default(auto()) @map("_id") @db.ObjectId
  deviceId  String     @db.ObjectId
  device    Device     @relation(fields: [deviceId], references: [id])
  status    PowerStatus
  timestamp DateTime   // when the transition actually happened (device clock)
  createdAt DateTime   @default(now()) // when the server received it

  @@index([deviceId, timestamp])
}

enum PowerStatus {
  ON
  OFF
}

// Manually logged (or later OCR'd) prepaid token purchases.
// Used to estimate consumption rate and predict when units will run out.
model TokenEntry {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  deviceId       String   @db.ObjectId
  device         Device   @relation(fields: [deviceId], references: [id])
  unitsPurchased Float    // kWh units bought
  amountPaid     Float    // Naira
  purchaseDate   DateTime
  createdAt      DateTime @default(now())

  @@index([deviceId, purchaseDate])
}
